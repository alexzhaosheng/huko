{
  "name": "@alexzhaosheng/huko",
  "version": "0.2.4",
  "description": "An explicit, scriptable AI agent for the command line. Pipe data in, get the answer out.",
  "keywords": [
    "ai",
    "agent",
    "cli",
    "llm",
    "claude",
    "openai",
    "anthropic",
    "deepseek"
  ],
  "homepage": "https://github.com/alexzhaosheng/huko#readme",
  "bugs": {
    "url": "https://github.com/alexzhaosheng/huko/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexzhaosheng/huko.git"
  },
  "license": "MIT",
  "author": "alexzhaosheng",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "bin": {
    "huko": "./bin/huko.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build:cli": "node scripts/build-cli.mjs",
    "check": "tsc --noEmit",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "huko": "tsx server/cli/index.ts",
    "test": "node --import tsx --test \"tests/*.test.ts\"",
    "prepublishOnly": "pnpm run check && pnpm run build:cli"
  },
  "dependencies": {
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "better-sqlite3": "^12.0.0",
    "dotenv": "^16.0.0",
    "drizzle-orm": "^0.44.0",
    "express": "^4.21.0",
    "iconv-lite": "^0.6.3",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "nanoid": "^5.0.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "ws": "^8.20.1",
    "zod": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3"
  }
}
