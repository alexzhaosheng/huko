{
  "name": "huko",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "bin": {
    "huko": "./bin/huko.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build:cli": "esbuild server/cli/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/cli.js",
    "check": "tsc --noEmit",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "huko": "tsx server/cli/index.ts",
    "test": "node --import tsx --test \"tests/*.test.ts\"",
    "prepublishOnly": "npm run check && npm run build:cli"
  },
  "dependencies": {
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "better-sqlite3": "^12.0.0",
    "drizzle-orm": "^0.44.0",
    "express": "^4.21.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "nanoid": "^5.0.0",
    "zod": "^4.0.0",
    "dotenv": "^16.0.0",
    "iconv-lite": "^0.6.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0"
  }
}
