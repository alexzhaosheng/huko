{
  "name": "huko",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch server/core/app.ts",
    "build": "esbuild server/core/app.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:cli": "esbuild server/cli/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/cli.js",
    "start": "cross-env NODE_ENV=production node dist/app.js",
    "check": "tsc --noEmit",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "huko": "tsx server/cli/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "better-sqlite3": "^12.0.0",
    "drizzle-orm": "^0.44.0",
    "express": "^4.21.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "nanoid": "^5.0.0",
    "zod": "^4.0.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "vitest": "^2.0.0"
  }
}
