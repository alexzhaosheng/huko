{
  "name": "huko",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch server/core/app.ts",
    "build": "vite build && esbuild server/core/app.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "cross-env NODE_ENV=production node dist/app.js",
    "check": "tsc --noEmit",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:migrate:dry": "tsx scripts/db-migrate.ts --dry-run",
    "test": "vitest run"
  },
  "dependencies": {
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@tanstack/react-query": "^5.0.0",
    "better-sqlite3": "^12.0.0",
    "drizzle-orm": "^0.44.0",
    "express": "^4.21.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "jose": "^6.0.0",
    "bcryptjs": "^3.0.0",
    "nanoid": "^5.0.0",
    "zod": "^4.0.0",
    "dotenv": "^16.0.0",
    "cookie": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "wouter": "^3.3.0",
    "zustand": "^5.0.0",
    "lucide-react": "^0.453.0",
    "tailwind-merge": "^3.0.0",
    "clsx": "^2.1.0",
    "sonner": "^2.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie": "^1.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^2.0.0"
  }
}
