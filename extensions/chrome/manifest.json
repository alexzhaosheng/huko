{
  "manifest_version": 3,
  "name": "huko browser control",
  "version": "1.0",
  "description": "Lets huko operate your browser — navigate, click, type, and read pages on your behalf.",
  "permissions": ["alarms", "tabs", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "huko_red.png",
      "48": "huko_red.png",
      "128": "huko_red.png"
    }
  },
  "icons": {
    "16": "huko.png",
    "48": "huko.png",
    "128": "huko.png"
  }
}
